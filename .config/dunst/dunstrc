# ~/.config/dunst/dunstrc
# Notificaciones con tema everforest (combina con la waybar/rice).
# Colores tomados de ~/.config/waybar/colors/everforest.css

[global]
    monitor = 0
    follow = mouse

    width = 360
    height = (0, 160)
    origin = top-right
    offset = (12, 12)
    gap_size = 6
    notification_limit = 5

    progress_bar = true
    progress_bar_height = 8
    progress_bar_frame_width = 1

    indicate_hidden = yes
    transparency = 0
    separator_height = 2
    padding = 10
    horizontal_padding = 12
    text_icon_padding = 8
    frame_width = 2
    frame_color = "#7d6a40"
    separator_color = frame
    corner_radius = 10
    sort = yes

    font = Noto Sans 10
    line_height = 0
    markup = full
    format = "<b>%s</b>\n%b"
    alignment = left
    vertical_alignment = center
    show_age_threshold = 60
    ellipsize = middle
    ignore_newline = no
    stack_duplicates = true
    hide_duplicate_count = false
    show_indicators = yes

    icon_position = left
    min_icon_size = 32
    max_icon_size = 64

    mouse_left_click = close_current
    mouse_middle_click = do_action, close_current
    mouse_right_click = close_all

[urgency_low]
    background = "#232a2e"
    foreground = "#859289"
    frame_color = "#56635f"
    timeout = 5

[urgency_normal]
    background = "#2d353b"
    foreground = "#d3c6aa"
    frame_color = "#7d6a40"
    timeout = 8

[urgency_critical]
    background = "#2d353b"
    foreground = "#d3c6aa"
    frame_color = "#e67e80"
    timeout = 0
