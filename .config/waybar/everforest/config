{
  "margin-top": 6,
  "margin-left": 8,
  "margin-bottom": 0,
  "margin-right": 8,
  "height": 0,
  "layer": "top",
  "position": "top",
  "spacing": 6,
  "modules-left": ["custom/launcher", "clock", "clock#date"],
  "modules-center": ["hyprland/workspaces"],
  "modules-right": ["backlight", "pulseaudio", "network", "bluetooth", "battery", "custom/dunst", "custom/powermenu"],

  "hyprland/workspaces": {
      "disable-scroll": true,
      "all-outputs": true,
      "on-click": "activate",
      "on-scroll-up": "hyprctl dispatch workspace e+1",
      "on-scroll-down": "hyprctl dispatch workspace e-1"
  },

  "custom/launcher": {
      "interval": "once",
      "format": "َ°£‡",
      "on-click": "pkill wofi || wofi --show drun --term=kitty --width 450 --height 520 --columns 1 -I -s ~/.config/wofi/themes/everforest.css",
      "tooltip": false
    },

    "backlight": {
      "device": "intel_backlight",
      "max-length": "4",
      "format": "{icon}",
      "tooltip-format": "{percent}%",
      "format-icons": ["َ°ƒڑ","َ°ƒ›","َ°ƒœ","َ°ƒ‌","َ°ƒ‍","َ°ƒں","َ°ƒ "],
      "on-click": "pkill -f brightmenu.py || python3 ~/.config/waybar/everforest/scripts/brightmenu.py",
      "on-scroll-up": "brightnessctl set +5%",
      "on-scroll-down": "brightnessctl set 5%-"
  },

  "memory": {
    "interval": 30,
    "format": "  {}%",
    "format-alt":" {used:0.1f}G",
    "max-length": 10
},

  "custom/dunst": {
      "exec": "~/.config/waybar/scripts/dunst.sh",
      "on-click": "dunstctl set-paused toggle",
      "restart-interval": 1,
      "tooltip": false
  },

  "pulseaudio": {
      "format": "{icon}",
      "format-bluetooth": "{icon}",
      "format-bluetooth-muted": "َ°‌ں",
      "format-muted": "َ°‌ں",
      "format-icons": {
          "headphone": "َ°‹‹",
          "hands-free": "َ°‹ژ",
          "headset": "َ°‹ژ",
          "phone": "َ°•¾",
          "portable": "َ°•¾",
          "car": "َ°„‹",
          "default": ["َ°•؟","َ°–€","َ°•¾"]
      },
      "on-click-right": "pavucontrol",
    "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
  },

"network": {
      "format-wifi": "{icon}",
      "format-ethernet": "َ°ˆ€",
      "format-disconnected": "َ°¤­",
      "format-icons": ["َ°¤ں","َ°¤¢","َ°¤¥","َ°¤¨"],
      "on-click": "sh ~/.config/wofi/scripts/wifimenu.sh everforest"
},

"bluetooth": {
      "format": "َ°‚¯",
      "format-disabled": "َ°‚²",
      "format-off": "َ°‚²",
      "format-connected": "َ°‚±",
      "tooltip-format": "{controller_alias}",
      "tooltip-format-connected": "{controller_alias}\n{num_connections} conectado(s)\n{device_enumerate}",
      "tooltip-format-enumerate-connected": "{device_alias}",
      "on-click": "pkill wofi || sh ~/.config/wofi/scripts/btmenu.sh 'everforest-compact' '--width 340 --height 300'"
},

"battery": {
    "bat": "BAT0",
    "adapter": "AC",
    "interval": 60,
    "states": {
        "warning": 30,
        "critical": 15
    },
    "max-length": 10,
    "format": "{icon}",
    "format-warning": "{icon}",
    "format-critical": "{icon}",
    "format-charging": "{icon}",
    "format-plugged": "{icon}",
    "format-alt": "{icon} {capacity}%",
    "format-full": "{icon}",
    "format-icons": ["َ°‚ژ","َ°پ؛","َ°پ»","َ°پ¼","َ°پ½","َ°پ¾","َ°پ؟","َ°‚€","َ°‚پ","َ°‚‚","َ°پ¹"]
},

"clock": {
    "format": " {:%H:%M}"
},

"clock#date": {
  "format": " {:%A, %B %d, %Y}"
},

"custom/powermenu": {
    "format": "ï€‘",
    "on-click": "pkill wofi || sh ~/.config/wofi/scripts/powermenu.sh 'everforest'",
    "tooltip": false
  }
}
