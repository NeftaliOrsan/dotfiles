{
  // --- Tema HyperOS (frosted glass oscuro azulado) ---
  // El "vidrio" lo pinta el blur de Hyprland sobre las pastillas translucidas
  // (ver hl.layer_rule "blur-waybar" en hyprland.lua). Aqui solo va estructura.
  "margin-top": 8,
  "margin-left": 12,
  "margin-bottom": 0,
  "margin-right": 12,
  "height": 0,
  "layer": "top",
  "position": "top",
  "spacing": 4,
  "modules-left": ["custom/launcher", "clock", "clock#date"],
  "modules-center": ["hyprland/workspaces"],
  "modules-right": ["backlight", "pulseaudio", "network", "bluetooth", "battery", "custom/dunst", "custom/powermenu"],

  "hyprland/workspaces": {
      "disable-scroll": true,
      "all-outputs": true,
      "on-click": "activate",
      "on-scroll-up": "hyprctl dispatch workspace e+1",
      "on-scroll-down": "hyprctl dispatch workspace e-1"
  },

  "custom/launcher": {
      "interval": "once",
      "format": "蟀",
      "on-click": "pkill wofi || wofi --show drun --term=kitty --width 450 --height 520 --columns 1 -I -s ~/.config/wofi/themes/hyperos.css",
      "tooltip": false
    },

    "backlight": {
      "device": "intel_backlight",
      "max-length": "4",
      "format": "{icon}",
      "tooltip-format": "{percent}%",
      "format-icons": ["蟀儦","蟀儧","蟀儨","蟀儩","蟀優","蟀儫","蟀儬"],
      "on-click": "pkill -f brightmenu.py || python3 ~/.config/waybar/everforest/scripts/brightmenu.py",
      "on-scroll-up": "brightnessctl set +5%",
      "on-scroll-down": "brightnessctl set 5%-"
  },

  "custom/dunst": {
      "exec": "~/.config/waybar/scripts/dunst.sh",
      "on-click": "dunstctl set-paused toggle",
      "restart-interval": 1,
      "tooltip": false
  },

  "pulseaudio": {
      "format": "{icon}",
      "format-bluetooth": "{icon}",
      "format-bluetooth-muted": "蟀潫",
      "format-muted": "蟀潫",
      "format-icons": {
          "headphone": "蟀媼",
          "hands-free": "蟀嫀",
          "headset": "蟀嫀",
          "phone": "蟀暰",
          "portable": "蟀暰",
          "car": "蟀剫",
          "default": ["蟀暱","蟀杸","蟀暰"]
      },
      "on-click-right": "pavucontrol",
    "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle"
  },

"network": {
      "format-wifi": "{icon}",
      "format-ethernet": "蟀垁",
      "format-disconnected": "蟀き",
      "format-icons": ["蟀","蟀あ","蟀ぅ","蟀え"],
      "tooltip-format-wifi": "{essid}  ({signalStrength}%)",
      "tooltip-format-ethernet": "Cableada  {ifname}",
      "tooltip-format-disconnected": "Sin conexi贸n",
      "on-click": "sh ~/.config/wofi/scripts/wifimenu.sh hyperos"
},

"bluetooth": {
      "format": "蟀偗",
      "format-disabled": "蟀偛",
      "format-off": "蟀偛",
      "format-connected": "蟀偙",
      "tooltip-format": "No hay dispositivos conectados",
      "tooltip-format-connected": "{num_connections} conectado(s)\n{device_enumerate}",
      "tooltip-format-enumerate-connected": "{device_alias}",
      "tooltip-format-off": "Bluetooth apagado",
      "tooltip-format-disabled": "Bluetooth deshabilitado",
      "on-click": "pkill wofi || sh ~/.config/wofi/scripts/btmenu.sh 'hyperos-compact' '--width 340 --height 300'"
},

"battery": {
    "bat": "BAT0",
    "adapter": "AC",
    "interval": 60,
    "states": {
        "warning": 30,
        "critical": 15
    },
    "max-length": 10,
    "format": "{icon}",
    "format-warning": "{icon}",
    "format-critical": "{icon}",
    "format-charging": "{icon}",
    "format-plugged": "{icon}",
    "format-alt": "{icon} {capacity}%",
    "format-full": "{icon}",
    "format-icons": ["蟀値","蟀伜","蟀伝","蟀伡","蟀伣","蟀伨","蟀伩","蟀個","蟀倎","蟀倐","蟀伖"]
},

"clock": {
    "format": "{:%H:%M}",
    "tooltip-format": "{:%A %d de %B de %Y}"
},

"clock#date": {
  "format": "{:%a %d %b}",
  "tooltip-format": "<span font='Noto Sans Mono 11'>{calendar}</span>",
  "calendar": {
      "mode": "month",
      "on-scroll": 1,
      "format": {
          "today":    "<span color='#4084ff'><b>{}</b></span>",
          "months":   "<span color='#eef2f6'><b>{}</b></span>",
          "weekdays": "<span color='#8a93a6'><b>{}</b></span>"
      }
  }
},

"custom/powermenu": {
    "format": "蟀惀",
    "on-click": "pkill wofi || sh ~/.config/wofi/scripts/powermenu.sh 'hyperos' '--height 240'",
    "tooltip": false
  }
}
